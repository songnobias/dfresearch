# dfresearch environment configuration
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# ── HuggingFace Hub ────────────────────────────────────────────────────────
# Token for downloading gated/private datasets and avoiding rate limits.
# Get yours at: https://huggingface.co/settings/tokens
# Without this, some datasets may fail to download or be rate-limited.
HF_TOKEN=

# ── Weights & Biases (optional) ───────────────────────────────────────────
# For experiment tracking. If set, training scripts will log to W&B.
# Get yours at: https://wandb.ai/authorize
# WANDB_API_KEY=
# WANDB_PROJECT=dfresearch

# ── Cache location (optional) ─────────────────────────────────────────────
# Override the default cache directory (~/.cache/dfresearch)
# DFRESEARCH_CACHE=~/.cache/dfresearch

# ── GPU settings (optional) ───────────────────────────────────────────────
# Restrict to a specific GPU (useful for multi-GPU machines)
# CUDA_VISIBLE_DEVICES=0

# ── HuggingFace Hub cache (optional) ──────────────────────────────────────
# Shared HF model cache. Saves re-downloading pretrained weights.
# HF_HOME=~/.cache/huggingface
