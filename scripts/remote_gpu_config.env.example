# Copy to remote_gpu_config.env and fill in. Do not commit secrets.
# Source from shell: set -a && . ./scripts/remote_gpu_config.env && set +a

# GPU host (user@hostname or user@ip)
REMOTE_USER_HOST="ubuntu@gpu-server.example.com"

# Path on the GPU machine where dfresearch lives (or will be created)
REMOTE_DFRESEARCH_ROOT="/home/ubuntu/dfresearch"

# Local path to dfresearch repo root (directory that contains train_image.py)
LOCAL_DFRESEARCH_ROOT="${LOCAL_DFRESEARCH_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"

# SSH key (optional; default is ssh-agent)
# SSH_IDENTITY_FILE="$HOME/.ssh/id_ed25519_gpu"

# rsync / SSH extra options
RSYNC_BANDWIDTH_LIMIT_KB=""
# RSYNC_EXTRA="--dry-run"
